rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "goldrock012@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Public access to product catalog
      allow write: if isAdmin(); // Only Admin can add/edit/delete products
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin(); // Only admins can approve/update/delete orders
    }

    // Carts Collection
    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Wishlists Collection
    match /wishlists/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true; // Public can view reviews
      allow create: if isSignedIn(); // Logged-in users can write reviews
      allow update, delete: if isAdmin(); // Only Admin can reply, hide, or delete reviews
    }
  }
}
